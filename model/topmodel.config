# yaml-language-server: $schema=./topmodel.config.schema.json
---
app: KleeContrib.Asta
i18n:
  translateReferences: false
  translateProperties: false
pluralizeTableNames: true
defaultAssociationUseClass: true

jpa:
  - tags: [back, commands, queries, api-commands]
    outputDirectory: ../sources/backend/src/main
    apiGeneration: Server
    metaModel: true
    daosPath: "java:{app:path}/daos/{module}"
    resourcesPath: "resources/locale"
    uniqueValueGeneration: enum-only
javascript:
  - tags: [front]
    outputDirectory: ../sources/frontend/src
    modelRootPath: model
    apiClientRootPath: services
    apiMode: angular
    resourceRootPath: locale
    domainPath: "@domains"
    fetchPath: ./server
    entityMode: focus
    extendedCompositions: true
    entityTypesPath: "@focus4/entities"
sql:
  - tags:
      - persist
    outputDirectory: ../env/db/init
    procedural:
      tablesFileName: 01_tables.sql
      indexesAndKeysFileName: 02_indexes_and_keys.sql
      valuesFileName: 03_values.sql
