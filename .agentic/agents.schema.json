{
    "type": "object",
    "properties": {
        "agents": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "runtime": {
                        "type": "string",
                        "enum": [
                            "local",
                            "cloud"
                        ],
                        "description": "Où s'exécute l'agent : « local » (sandbox local/conteneur) ou « cloud » (agent Cursor Cloud managé). Défaut : local."
                    },
                    "model": {
                        "anyOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                    },
                                    "params": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                    }
                                },
                                "required": [
                                    "id"
                                ],
                                "additionalProperties": false
                            },
                            {
                                "type": "string"
                            }
                        ],
                        "description": "Modèle : la forme courte « id » (ex. « composer-2.5 ») ou « { id, params } » pour passer des réglages."
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Répertoire de travail des agents LOCAUX in-process (relatif à la racine projet). Ignoré en mode conteneur (exécution dans /workspace)."
                    },
                    "sandbox": {
                        "type": "boolean",
                        "description": "Active le sandbox de commandes du SDK Cursor (agents locaux). À ne pas confondre avec « sandbox.docker » de agentic.config.yml."
                    },
                    "autoReview": {
                        "type": "boolean",
                        "description": "Lance le classifieur d'auto-revue du SDK sur les actions de l'agent (local). Désactivé par défaut."
                    },
                    "settingSources": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "project",
                                "user",
                                "team",
                                "mdm",
                                "plugins",
                                "all"
                            ]
                        },
                        "description": "Sources de réglages/règles Cursor à charger (project, user, team, mdm, plugins, all). Agents locaux Cursor uniquement."
                    },
                    "mcpServers": {
                        "type": "object",
                        "additionalProperties": {},
                        "description": "Serveurs MCP de l'agent : références « { use, with?, secrets? } » au catalogue (ou config inline si allowFreeformMcp)."
                    },
                    "subagents": {
                        "type": "array",
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "use": {
                                            "type": "string",
                                            "description": "Nom d'un agent du pool (après fusion des défauts) à enrôler comme sous-agent."
                                        },
                                        "model": {
                                            "anyOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "id": {
                                                            "type": "string",
                                                            "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                                        },
                                                        "params": {
                                                            "type": "object",
                                                            "additionalProperties": {
                                                                "type": "string"
                                                            },
                                                            "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                                        }
                                                    },
                                                    "required": [
                                                        "id"
                                                    ],
                                                    "additionalProperties": false
                                                },
                                                {
                                                    "type": "string",
                                                    "const": "inherit"
                                                }
                                            ],
                                            "description": "Surcharge le modèle pour cette délégation ; « inherit » reprend celui de l'appelant. Sinon le modèle propre de l'agent du pool."
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "Surcharge l'indice de délégation (sinon la « description » de l'agent du pool)."
                                        }
                                    },
                                    "required": [
                                        "use"
                                    ],
                                    "additionalProperties": false
                                }
                            ],
                            "description": "Un sous-agent : le nom d'un agent du pool (chaîne) ou « { use, model?, description? } » avec surcharges."
                        },
                        "description": "Équipe de délégation : liste de références au pool d'agents, résolues en sous-agents inline."
                    },
                    "cloud": {
                        "type": "object",
                        "properties": {
                            "env": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "cloud",
                                            "pool",
                                            "machine"
                                        ],
                                        "description": "Type d'environnement de l'agent cloud : cloud, pool ou machine."
                                    },
                                    "name": {
                                        "type": "string",
                                        "description": "Nom de l'environnement/pool/machine ciblé."
                                    }
                                },
                                "required": [
                                    "type"
                                ],
                                "additionalProperties": false,
                                "description": "Environnement d'exécution de l'agent cloud."
                            },
                            "repos": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "url": {
                                            "type": "string",
                                            "description": "URL d'un dépôt mis à disposition de l'agent cloud."
                                        },
                                        "startingRef": {
                                            "type": "string",
                                            "description": "Branche/ref de départ pour ce dépôt."
                                        },
                                        "prUrl": {
                                            "type": "string",
                                            "description": "URL d'une PR existante à poursuivre, le cas échéant."
                                        }
                                    },
                                    "required": [
                                        "url"
                                    ],
                                    "additionalProperties": false
                                },
                                "description": "Dépôts mis à disposition de l'agent cloud."
                            },
                            "autoCreatePR": {
                                "type": "boolean",
                                "description": "Ouvrir automatiquement une PR à la fin du travail de l'agent cloud."
                            },
                            "workOnCurrentBranch": {
                                "type": "boolean",
                                "description": "Travailler sur la branche courante plutôt que d'en créer une nouvelle."
                            },
                            "skipReviewerRequest": {
                                "type": "boolean",
                                "description": "Ne pas demander automatiquement de relecteur sur la PR."
                            },
                            "envVars": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                },
                                "description": "Variables d'environnement injectées dans l'agent cloud (map clé→valeur)."
                            }
                        },
                        "additionalProperties": false,
                        "description": "Options de l'agent cloud (prises en compte quand runtime: cloud)."
                    },
                    "mode": {
                        "type": "string",
                        "enum": [
                            "edit",
                            "read-only"
                        ],
                        "description": "« edit » (l'agent modifie) ou « read-only » (mode plan). Ce n'est PAS un verrou système de fichiers."
                    },
                    "description": {
                        "type": "string",
                        "description": "Indice de délégation : lu par l'orchestrateur pour décider quand déléguer à cet agent (quand il sert de sous-agent)."
                    },
                    "systemPrompt": {
                        "type": "string",
                        "description": "Instructions de base ajoutées en tête de chaque prompt utilisant ce profil (templatées)."
                    },
                    "engine": {
                        "type": "string",
                        "description": "Moteur qui pilote l'étape (cursor | opencode | …). Défaut : cursor ; le modèle est pris dans le catalogue de ce moteur."
                    },
                    "engineOptions": {
                        "type": "object",
                        "additionalProperties": {},
                        "description": "Options opaques par moteur, indexées par id de moteur (ex. « { opencode: { … } } »)."
                    }
                },
                "additionalProperties": false
            },
            "description": "Pool de profils d'agents réutilisables, indexés par nom (fusionné avec les agents par défaut ; le projet l'emporte par nom)."
        }
    },
    "required": [
        "agents"
    ],
    "additionalProperties": false,
    "description": "Fichier .agentic/agents.yml — le pool d'agents réutilisables du projet.",
    "$schema": "http://json-schema.org/draft-07/schema#"
}