{
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "Nom du workflow : sert à le lancer/résoudre et à nommer chaque étape « \u003Cname\u003E/\u003CstepId\u003E »."
        },
        "description": {
            "type": "string",
            "description": "Description du workflow (affichage/catalogue uniquement ; aucun effet à l'exécution)."
        },
        "inputs": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "required": {
                        "type": "boolean",
                        "description": "Si vrai et qu'aucune valeur ni « default » n'est fournie au lancement, le run échoue (entrée requise manquante)."
                    },
                    "description": {
                        "type": "string",
                        "description": "Description de l'entrée, affichée dans le formulaire de lancement et la doc d'API."
                    },
                    "default": {
                        "type": "string",
                        "description": "Valeur par défaut si l'entrée n'est pas fournie (ou vide)."
                    }
                },
                "additionalProperties": false
            },
            "description": "Entrées du run, indexées par nom ; exposées aux templates via « {{ inputs.\u003Cnom\u003E }} »."
        },
        "defaults": {
            "type": "object",
            "properties": {
                "runtime": {
                    "type": "string",
                    "enum": [
                        "local",
                        "cloud"
                    ],
                    "description": "Où s'exécute l'agent : « local » (sandbox local/conteneur) ou « cloud » (agent Cursor Cloud managé). Défaut : local."
                },
                "model": {
                    "anyOf": [
                        {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                },
                                "params": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    },
                                    "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                }
                            },
                            "required": [
                                "id"
                            ],
                            "additionalProperties": false
                        },
                        {
                            "type": "string"
                        }
                    ],
                    "description": "Modèle : la forme courte « id » (ex. « composer-2.5 ») ou « { id, params } » pour passer des réglages."
                },
                "cwd": {
                    "type": "string",
                    "description": "Répertoire de travail des agents LOCAUX in-process (relatif à la racine projet). Ignoré en mode conteneur (exécution dans /workspace)."
                },
                "sandbox": {
                    "type": "boolean",
                    "description": "Active le sandbox de commandes du SDK Cursor (agents locaux). À ne pas confondre avec « sandbox.docker » de agentic.config.yml."
                },
                "autoReview": {
                    "type": "boolean",
                    "description": "Lance le classifieur d'auto-revue du SDK sur les actions de l'agent (local). Désactivé par défaut."
                },
                "settingSources": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "project",
                            "user",
                            "team",
                            "mdm",
                            "plugins",
                            "all"
                        ]
                    },
                    "description": "Sources de réglages/règles Cursor à charger (project, user, team, mdm, plugins, all). Agents locaux Cursor uniquement."
                },
                "mcpServers": {
                    "type": "object",
                    "additionalProperties": {},
                    "description": "Serveurs MCP de l'agent : références « { use, with?, secrets? } » au catalogue (ou config inline si allowFreeformMcp)."
                },
                "subagents": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "use": {
                                        "type": "string",
                                        "description": "Nom d'un agent du pool (après fusion des défauts) à enrôler comme sous-agent."
                                    },
                                    "model": {
                                        "anyOf": [
                                            {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "string",
                                                        "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                                    },
                                                    "params": {
                                                        "type": "object",
                                                        "additionalProperties": {
                                                            "type": "string"
                                                        },
                                                        "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                                    }
                                                },
                                                "required": [
                                                    "id"
                                                ],
                                                "additionalProperties": false
                                            },
                                            {
                                                "type": "string",
                                                "const": "inherit"
                                            }
                                        ],
                                        "description": "Surcharge le modèle pour cette délégation ; « inherit » reprend celui de l'appelant. Sinon le modèle propre de l'agent du pool."
                                    },
                                    "description": {
                                        "type": "string",
                                        "description": "Surcharge l'indice de délégation (sinon la « description » de l'agent du pool)."
                                    }
                                },
                                "required": [
                                    "use"
                                ],
                                "additionalProperties": false
                            }
                        ],
                        "description": "Un sous-agent : le nom d'un agent du pool (chaîne) ou « { use, model?, description? } » avec surcharges."
                    },
                    "description": "Équipe de délégation : liste de références au pool d'agents, résolues en sous-agents inline."
                },
                "cloud": {
                    "type": "object",
                    "properties": {
                        "env": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "cloud",
                                        "pool",
                                        "machine"
                                    ],
                                    "description": "Type d'environnement de l'agent cloud : cloud, pool ou machine."
                                },
                                "name": {
                                    "type": "string",
                                    "description": "Nom de l'environnement/pool/machine ciblé."
                                }
                            },
                            "required": [
                                "type"
                            ],
                            "additionalProperties": false,
                            "description": "Environnement d'exécution de l'agent cloud."
                        },
                        "repos": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "url": {
                                        "type": "string",
                                        "description": "URL d'un dépôt mis à disposition de l'agent cloud."
                                    },
                                    "startingRef": {
                                        "type": "string",
                                        "description": "Branche/ref de départ pour ce dépôt."
                                    },
                                    "prUrl": {
                                        "type": "string",
                                        "description": "URL d'une PR existante à poursuivre, le cas échéant."
                                    }
                                },
                                "required": [
                                    "url"
                                ],
                                "additionalProperties": false
                            },
                            "description": "Dépôts mis à disposition de l'agent cloud."
                        },
                        "autoCreatePR": {
                            "type": "boolean",
                            "description": "Ouvrir automatiquement une PR à la fin du travail de l'agent cloud."
                        },
                        "workOnCurrentBranch": {
                            "type": "boolean",
                            "description": "Travailler sur la branche courante plutôt que d'en créer une nouvelle."
                        },
                        "skipReviewerRequest": {
                            "type": "boolean",
                            "description": "Ne pas demander automatiquement de relecteur sur la PR."
                        },
                        "envVars": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            },
                            "description": "Variables d'environnement injectées dans l'agent cloud (map clé→valeur)."
                        }
                    },
                    "additionalProperties": false,
                    "description": "Options de l'agent cloud (prises en compte quand runtime: cloud)."
                },
                "mode": {
                    "type": "string",
                    "enum": [
                        "edit",
                        "read-only"
                    ],
                    "description": "« edit » (l'agent modifie) ou « read-only » (mode plan). Ce n'est PAS un verrou système de fichiers."
                },
                "description": {
                    "type": "string",
                    "description": "Indice de délégation : lu par l'orchestrateur pour décider quand déléguer à cet agent (quand il sert de sous-agent)."
                },
                "systemPrompt": {
                    "type": "string",
                    "description": "Instructions de base ajoutées en tête de chaque prompt utilisant ce profil (templatées)."
                },
                "engine": {
                    "type": "string",
                    "description": "Moteur qui pilote l'étape (cursor | opencode | …). Défaut : cursor ; le modèle est pris dans le catalogue de ce moteur."
                },
                "engineOptions": {
                    "type": "object",
                    "additionalProperties": {},
                    "description": "Options opaques par moteur, indexées par id de moteur (ex. « { opencode: { … } } »)."
                }
            },
            "additionalProperties": false,
            "description": "Profil d'agent par défaut du workflow (sous l'étape et le profil nommé, au-dessus des défauts projet)."
        },
        "steps": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9_-]+$",
                        "description": "Identifiant unique de l'étape (alphanumérique, tiret, underscore). Cible de « {{ steps.\u003Cid\u003E.result }} », « receives », « continue » et « goto »."
                    },
                    "title": {
                        "type": "string",
                        "description": "Libellé d'affichage de l'étape. Défaut : l'id."
                    },
                    "agent": {
                        "type": "string",
                        "description": "Profil d'agent (du pool fusionné) à utiliser pour cette étape. Omis ⇒ profil par défaut."
                    },
                    "continue": {
                        "type": "string",
                        "description": "Réutilise (reprend) l'agent d'une étape ANTÉRIEURE au lieu d'en créer un neuf. Préférez « receives » pour passer du contexte (plus robuste)."
                    },
                    "receives": {
                        "type": "array",
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string",
                                    "description": "Forme courte : l'id de l'étape source (étiquette = titre de cette étape)."
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "from": {
                                            "type": "string",
                                            "description": "Id de l'étape source (doit être ANTÉRIEURE)."
                                        },
                                        "as": {
                                            "type": "string",
                                            "description": "Étiquette du bloc inséré (sinon le titre, sinon l'id de la source)."
                                        }
                                    },
                                    "required": [
                                        "from"
                                    ],
                                    "additionalProperties": false
                                }
                            ],
                            "description": "Reçoit le résultat d'une étape antérieure, inséré en tête du prompt comme bloc étiqueté (sucre pour « {{ steps.\u003Cfrom\u003E.result }} »)."
                        },
                        "description": "Entrées issues d'étapes antérieures, ajoutées au prompt comme blocs de résultats étiquetés."
                    },
                    "prompt": {
                        "type": "string",
                        "description": "La tâche confiée à l'agent. Templatée ({{ inputs.x }}, {{ steps.y.result }}, …)."
                    },
                    "model": {
                        "anyOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                    },
                                    "params": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                    }
                                },
                                "required": [
                                    "id"
                                ],
                                "additionalProperties": false
                            },
                            {
                                "type": "string"
                            }
                        ],
                        "description": "Modèle pour cette étape (surcharge le profil et les défauts)."
                    },
                    "mode": {
                        "type": "string",
                        "enum": [
                            "edit",
                            "read-only"
                        ],
                        "description": "« edit » ou « read-only » (mode plan), surcharge le profil. Ce n'est pas un verrou système de fichiers."
                    },
                    "runtime": {
                        "type": "string",
                        "enum": [
                            "local",
                            "cloud"
                        ],
                        "description": "« local » ou « cloud » (surcharge profil/défauts). Défaut : local. « cloud » interdit check, review et les MCP porteurs de secrets."
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Répertoire de travail (agents locaux in-process, relatif à la racine projet) ; c'est aussi le cwd de « check »."
                    },
                    "sandbox": {
                        "type": "boolean",
                        "description": "Sandbox de commandes du SDK Cursor (agents locaux)."
                    },
                    "autoReview": {
                        "type": "boolean",
                        "description": "Auto-revue du SDK sur les actions de l'agent (local)."
                    },
                    "settingSources": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "project",
                                "user",
                                "team",
                                "mdm",
                                "plugins",
                                "all"
                            ]
                        },
                        "description": "Sources de réglages/règles Cursor à charger (project, user, team, mdm, plugins, all). Agents locaux Cursor uniquement."
                    },
                    "mcpServers": {
                        "type": "object",
                        "additionalProperties": {},
                        "description": "Serveurs MCP pour cette étape (références au catalogue). Surcharge le profil."
                    },
                    "subagents": {
                        "type": "array",
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "use": {
                                            "type": "string",
                                            "description": "Nom d'un agent du pool (après fusion des défauts) à enrôler comme sous-agent."
                                        },
                                        "model": {
                                            "anyOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "id": {
                                                            "type": "string",
                                                            "description": "Identifiant du modèle dans le catalogue du moteur (ex. « composer-2.5 »)."
                                                        },
                                                        "params": {
                                                            "type": "object",
                                                            "additionalProperties": {
                                                                "type": "string"
                                                            },
                                                            "description": "Paramètres de réglage du modèle, en map (ex. « thinking: high »)."
                                                        }
                                                    },
                                                    "required": [
                                                        "id"
                                                    ],
                                                    "additionalProperties": false
                                                },
                                                {
                                                    "type": "string",
                                                    "const": "inherit"
                                                }
                                            ],
                                            "description": "Surcharge le modèle pour cette délégation ; « inherit » reprend celui de l'appelant. Sinon le modèle propre de l'agent du pool."
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "Surcharge l'indice de délégation (sinon la « description » de l'agent du pool)."
                                        }
                                    },
                                    "required": [
                                        "use"
                                    ],
                                    "additionalProperties": false
                                }
                            ],
                            "description": "Un sous-agent : le nom d'un agent du pool (chaîne) ou « { use, model?, description? } » avec surcharges."
                        },
                        "description": "Équipe de délégation de l'étape : REMPLACE (ne fusionne pas) celle du profil."
                    },
                    "cloud": {
                        "type": "object",
                        "properties": {
                            "env": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "cloud",
                                            "pool",
                                            "machine"
                                        ],
                                        "description": "Type d'environnement de l'agent cloud : cloud, pool ou machine."
                                    },
                                    "name": {
                                        "type": "string",
                                        "description": "Nom de l'environnement/pool/machine ciblé."
                                    }
                                },
                                "required": [
                                    "type"
                                ],
                                "additionalProperties": false,
                                "description": "Environnement d'exécution de l'agent cloud."
                            },
                            "repos": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "url": {
                                            "type": "string",
                                            "description": "URL d'un dépôt mis à disposition de l'agent cloud."
                                        },
                                        "startingRef": {
                                            "type": "string",
                                            "description": "Branche/ref de départ pour ce dépôt."
                                        },
                                        "prUrl": {
                                            "type": "string",
                                            "description": "URL d'une PR existante à poursuivre, le cas échéant."
                                        }
                                    },
                                    "required": [
                                        "url"
                                    ],
                                    "additionalProperties": false
                                },
                                "description": "Dépôts mis à disposition de l'agent cloud."
                            },
                            "autoCreatePR": {
                                "type": "boolean",
                                "description": "Ouvrir automatiquement une PR à la fin du travail de l'agent cloud."
                            },
                            "workOnCurrentBranch": {
                                "type": "boolean",
                                "description": "Travailler sur la branche courante plutôt que d'en créer une nouvelle."
                            },
                            "skipReviewerRequest": {
                                "type": "boolean",
                                "description": "Ne pas demander automatiquement de relecteur sur la PR."
                            },
                            "envVars": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                },
                                "description": "Variables d'environnement injectées dans l'agent cloud (map clé→valeur)."
                            }
                        },
                        "additionalProperties": false,
                        "description": "Options de l'agent cloud (si runtime: cloud)."
                    },
                    "systemPrompt": {
                        "type": "string",
                        "description": "Instructions de base pour cette étape (surcharge celles du profil)."
                    },
                    "continueOnError": {
                        "type": "boolean",
                        "description": "Si l'étape finit en erreur, poursuivre l'étape suivante au lieu d'arrêter le run (le run final reste en erreur)."
                    },
                    "check": {
                        "type": "string",
                        "description": "Commande shell lancée par le MOTEUR après le tour de l'agent ; code de sortie 0 = succès (le self-report du modèle n'est jamais cru). Templatée. Interdite en runtime cloud."
                    },
                    "repeat": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "description": "Nombre max de tours « checkés » : sur check en échec, le même agent est relancé avec la sortie capturée, jusqu'à « repeat » fois. Défaut : 1. Nécessite « check »."
                    },
                    "review": {
                        "type": "object",
                        "properties": {
                            "agent": {
                                "type": "string",
                                "description": "Profil de l'agent juge. Omis ⇒ juge par défaut. Le juge tourne en local + mode edit (pour lancer les gates et lire le diff)."
                            },
                            "criteria": {
                                "type": "string",
                                "description": "La grille du « done » : ce que le juge vérifie. Templatée."
                            },
                            "maxRepeats": {
                                "type": "integer",
                                "exclusiveMinimum": 0,
                                "default": 2,
                                "description": "Nombre de reprises du producteur autorisées sur un verdict REDO. Défaut : 2."
                            },
                            "onExhausted": {
                                "type": "object",
                                "properties": {
                                    "goto": {
                                        "type": "string",
                                        "description": "Id d'une étape ANTÉRIEURE vers laquelle reboucler quand la revue échoue après épuisement des reprises."
                                    },
                                    "maxLoops": {
                                        "type": "integer",
                                        "exclusiveMinimum": 0,
                                        "description": "Nombre maximal de retours-arrière pour cette arête (borne dure)."
                                    },
                                    "then": {
                                        "type": "string",
                                        "enum": [
                                            "fail",
                                            "continue"
                                        ],
                                        "default": "fail",
                                        "description": "Après épuisement des boucles : « fail » (échec du run) ou « continue » (poursuivre avec réserves). Défaut : fail."
                                    }
                                },
                                "required": [
                                    "goto",
                                    "maxLoops"
                                ],
                                "additionalProperties": false,
                                "description": "Retour-arrière déclenché si les reprises s'épuisent sans PASS (voir « loop »)."
                            },
                            "onRedo": {
                                "type": "string",
                                "enum": [
                                    "resume",
                                    "fresh",
                                    "auto"
                                ],
                                "default": "auto",
                                "description": "Reprise sur REDO : « resume » (même agent), « fresh » (agent neuf) ou « auto » (le juge choisit, bascule en fresh au dernier essai). Défaut : auto."
                            }
                        },
                        "required": [
                            "criteria"
                        ],
                        "additionalProperties": false,
                        "description": "Vérification déléguée à un agent juge après l'étape (voir « review »)."
                    },
                    "approval": {
                        "anyOf": [
                            {
                                "type": "boolean",
                                "const": true
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "agent": {
                                        "type": "string",
                                        "description": "Profil de l'agent décideur. Omis ⇒ décideur par défaut (local + edit)."
                                    },
                                    "criteria": {
                                        "type": "string",
                                        "description": "Quand escalader vers un humain (templaté). Décision analysée fail-closed vers ESCALADE."
                                    },
                                    "timeout": {
                                        "type": "string",
                                        "description": "Délai d'attente du signal humain (durée Temporal, ex. « 2 days »). Défaut : 7 jours ; dépassé ⇒ traité comme un rejet."
                                    }
                                },
                                "required": [
                                    "criteria"
                                ],
                                "additionalProperties": false
                            }
                        ],
                        "description": "Point d'approbation humaine après l'étape (voir « approval »)."
                    },
                    "engine": {
                        "type": "string",
                        "description": "Moteur de l'étape (cursor | opencode | …). Défaut : cursor."
                    },
                    "engineOptions": {
                        "type": "object",
                        "additionalProperties": {},
                        "description": "Options opaques du moteur (indexées par id de moteur)."
                    }
                },
                "required": [
                    "id",
                    "prompt"
                ],
                "additionalProperties": false
            },
            "minItems": 1,
            "description": "Agenda ordonné des étapes, exécutées dans l'ordre. Au moins une étape."
        },
        "dynamic": {
            "type": "object",
            "properties": {
                "maxSteps": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 20,
                    "description": "Budget dur d'étapes ajoutées dynamiquement par run (1 à 20). Toute insertion passe d'abord une approbation humaine."
                }
            },
            "required": [
                "maxSteps"
            ],
            "additionalProperties": false,
            "description": "Active l'agenda dynamique : les producteurs peuvent proposer de nouvelles étapes en cours de run (sous approbation humaine)."
        }
    },
    "required": [
        "name",
        "steps"
    ],
    "additionalProperties": false,
    "description": "Fichier .agentic/workflows/\u003Cnom\u003E.yml — un workflow : ses entrées, ses défauts et son agenda d'étapes.",
    "$schema": "http://json-schema.org/draft-07/schema#"
}